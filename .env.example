# CodeForge - Local Developer Configuration
# Place this file at your project root or ~/.codeforge/.env
# This tells local CLI/GUI to talk to your production cPanel server

# -----------------------------------------------
# Full API URL for the production daemon
# -----------------------------------------------
CODEFORGE_API_URL=https://apicodeforge.khajumsanjog.com

# To use locally (comment out the API_URL above):
# CODEFORGE_PORT=7080
