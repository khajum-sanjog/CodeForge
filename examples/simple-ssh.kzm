project "My Node App"
description "Node.js app deployed to SSH server"

watch github "myuser/my-app" on branch "main"

before deploy:
  run "npm install"
  run "npm test"  must pass

deploy to ssh "ubuntu@192.168.1.100" at "/var/www/my-app":
  key     "~/.ssh/deploy_key"
  restart "pm2 restart my-app"

keep last 5

notify slack "#deployments"
